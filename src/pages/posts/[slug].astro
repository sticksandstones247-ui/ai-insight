---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts', ({ data }) => !data.draft))
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime() || a.id.localeCompare(b.id));
  return posts.map((post, i) => {
    const next = posts.length > 1 ? posts[(i + 1) % posts.length] : null;
    return {
      params: { slug: post.id },
      props: {
        post,
        prev: i > 0 ? posts[i - 1] : null,
        next,
        isLast: i === posts.length - 1,
      },
    };
  });
}

const { post, prev, next, isLast } = Astro.props;
const { Content } = await render(post);
---
<PostLayout post={post} prev={prev} next={next} isLast={isLast}>
  <Content />
</PostLayout>
